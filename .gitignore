# Python virtual environments
venv/
.venv/

# Python cache
__pycache__/
*.pyc

# Environment files
.env
.env.*
!.env.example

# Local and generated data. Deterministic demo inputs live in data/samples/.
data/raw/*
data/processed/*
data/exports/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/exports/.gitkeep

# Local databases, caches and test output
database/*.db
*.sqlite3
*.tsbuildinfo
.pytest_cache/
.ruff_cache/
.mypy_cache/
coverage.xml
htmlcov/

# JavaScript and PHP dependencies/build output
node_modules/
vendor/
dist/
