{
  "openapi": "3.0.3",
  "info": {"title": "FantaAnalytics Read API", "version": "0.1.0"},
  "paths": {
    "/health": {"get": {"responses": {"200": {"description": "Processo analytics vivo"}}}},
    "/ready": {"get": {"responses": {"200": {"description": "Database e schema pronti"}, "503": {"description": "Database o schema non pronti"}}}},
    "/api/v1/players": {"get": {"parameters": [{"name": "role", "in": "query"}, {"name": "team", "in": "query"}, {"name": "season", "in": "query"}], "responses": {"200": {"description": "Giocatori paginati"}}}},
    "/api/v1/players/{id}": {"get": {"parameters": [{"name": "id", "in": "path", "required": true}], "responses": {"200": {"description": "Giocatore"}, "404": {"description": "Non trovato"}}}},
    "/api/v1/import-runs": {"get": {"responses": {"200": {"description": "Import run"}}}}
  }
}
